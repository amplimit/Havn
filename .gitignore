# fastembed-rs lazy model cache. Created on first embed call when the
# operator opts into `provider = "local"` and runs from the repo root.
# Models are ~30-200 MB ONNX files — never want these in git.
/.fastembed_cache/
**/.fastembed_cache/

# playwright-cli artefacts. The CLI drops snapshot YAMLs in its CWD by
# default; if a developer invokes it from the repo root during testing
# those land here. Agent workspaces are gitignored via `/var/`.
/.playwright-cli/
**/.playwright-cli/
test-deploy/
